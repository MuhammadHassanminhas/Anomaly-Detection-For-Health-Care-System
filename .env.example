# Source (INDICI_BI_Full) — read-only connection. Never commit real values (D-002).
CDSS_SOURCE_HOST=
CDSS_SOURCE_PORT=1433
CDSS_SOURCE_DB=INDICI_BI_Full
# windows = Integrated/Windows Authentication (no USER/PASSWORD needed); sql = SQL login
CDSS_SOURCE_AUTH=windows
CDSS_SOURCE_ENCRYPT=true
CDSS_SOURCE_TRUST_SERVER_CERTIFICATE=true
# Only required when CDSS_SOURCE_AUTH=sql
CDSS_SOURCE_USER=
CDSS_SOURCE_PASSWORD=

# LLM (D-004 — provider/model not yet decided; OpenAI key present but unused by Phase 0)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# App DB (D-005 — local native PostgreSQL 18, not Docker; see DECISIONS.md D-005/D-026)
CDSS_APP_DB_URL=postgresql+psycopg://cdss_app:PASSWORD@localhost:5432/cdss_app
